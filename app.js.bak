async function openSubsectorDrilldown(mainSectorLabel){
  const f = currentOverviewFilters();
  // force sector to the clicked main sector
  const data = await apiGet({ action:"subsectors", year:f.year, state_name:f.state_name, sector_name:mainSectorLabel, source_name:f.source_name });
  const labels = (data||[]).map(x=>x.label);
  const values = (data||[]).map(x=>x.value);

  const _st = $("subsectorTitle"); if(_st) _st.textContent = `FINANCING BY SUB-SECTOR — ${mainSectorLabel}`;
  const _ss = $("subsectorSubtitle"); if(_ss) _ss.textContent = `Filtered by Year=${f.year}, State=${f.state_name}, Source=${f.source_name}`;

  destroyIf(subsectorChart);
  subsectorChart = makeBarBig("subsectorChart", labels, values);
  openModal("subsectorModal");
}


function makeDoughnut(id, pct) {
  const _id = arguments[0];
  const _el = $(_id);
  if (!_el) { console.warn("Missing canvas:", _id); return null; }
  const ctx = $(id);
  if (!ctx) return null;
  const p = Math.max(0, Math.min(100, Number(pct)||0));
  return new Chart(ctx, {
    type:"doughnut",
    data:{ labels:["Closed","Remaining"], datasets:[{ data:[p, 100-p], borderWidth:0 }] },
    options:{ responsive:true, maintainAspectRatio:false, cutout:"78%", plugins:{ legend:{display:false} } }
  });
}


function makeGapClosedStacked(id, labels, closedPct){
  const ctx = $(id); if(!ctx) return null;
  const vals = (closedPct||[]).map(v=> Math.max(0, Math.min(100, Number(v)||0)));
  const remaining = vals.map(v=> 100 - v);
  return new Chart(ctx,{
    type:"bar",
    data:{
      labels,
      datasets:[
        {
          label:"Remaining",
          data: remaining,
          backgroundColor:"rgba(129, 102, 238, 0.85)",
          borderWidth:0,
          borderRadius:{topLeft:0, topRight:0, bottomLeft:10, bottomRight:10},
          stack:"s"
        },
        {
          label:"Closed",
          data: vals,
          backgroundColor:"rgba(56, 214, 156, 0.95)",
          borderWidth:0,
          borderRadius:{topLeft:10, topRight:10, bottomLeft:0, bottomRight:0},
          stack:"s"
        }
      ]
    },
    options:{
      devicePixelRatio: Math.max(2, (window.devicePixelRatio||1)),
      responsive:true, maintainAspectRatio:false,
      plugins:{
        legend:{display:false},
        datalabels:{ display:false },
        tooltip:{ callbacks:{ label:(c)=> `${c.dataset.label}: ${Number(c.raw).toFixed(0)}%` } }
      },
      scales:{
        // Show year/category labels (same sizing as TOTAL FINANCING MOBILISED BY YEAR)
        x:{ stacked:true, grid:{display:false}, ticks:{display:false, color:"#2b2740", font:{size:14, weight:'700'}, padding:6 } },
        y:{ stacked:true, grid:{display:false}, ticks:{display:false}, suggestedMax:100, beginAtZero:true }
      }
    }
  });
}


